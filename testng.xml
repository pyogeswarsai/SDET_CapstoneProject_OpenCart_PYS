<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite thread-count="2" parallel="tests" name="OpenCart Suite">
  <test name="Chrome Test">
  	<parameter name="browser" value="chrome"/>
    <classes>
      <class name="Runners.OpenCartRunner"/>
    </classes>
  </test> <!-- Test -->
  <test name="Edge Test">
  	<parameter name="browser" value="edge"/>
    <classes>
      <class name="Runners.OpenCartRunner"/>
    </classes>
  </test> <!-- Test -->
</suite> <!-- OpenCart Parallel Suite -->